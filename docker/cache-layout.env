# Shared package / tool cache layout (absolute under CACHE_ROOT).
# SSOT for documentation and docker/setup-cache.sh.
# Do not put host-specific paths here — only names under CACHE_ROOT.

CACHE_ROOT=/cache

# mise: installed tools + download cache (shared across containers)
CACHE_MISE_DATA=mise
CACHE_MISE_CACHE=mise-cache

# Bundler (Ruby)
CACHE_BUNDLE=bundle
CACHE_RUBYGEMS=rubygems

# Classic Yarn 1.x
#   yarn/       → offline mirror (yarn-offline-mirror in classic .yarnrc)
#   yarn-cache/ → YARN_CACHE_FOLDER
CACHE_YARN_MIRROR=yarn
CACHE_YARN_FOLDER=yarn-cache

# Modern Yarn (Berry 2+)
#   yarn-global/ → YARN_GLOBAL_FOLDER (with enableGlobalCache)
#   yarn-cache/  → also YARN_CACHE_FOLDER / cacheFolder (shared name; different on-disk format)
# Do not mix classic offline-mirror tarballs with Berry zip caches in the same role.
CACHE_YARN_GLOBAL=yarn-global

# npm
CACHE_NPM=npm

# Python
#   pip/     → PIP_CACHE_DIR (wheel/sdist HTTP cache)
#   uv/      → UV_CACHE_DIR (not interchangeable with pip)
#   poetry/  → POETRY_CACHE_DIR (package cache; keep venvs in-project)
CACHE_PIP=pip
CACHE_UV=uv
CACHE_POETRY=poetry
