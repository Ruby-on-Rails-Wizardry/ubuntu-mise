#!/usr/bin/env bash
# Export / print shared cache paths for mise base images.
#
# Usage:
#   source cache-env                 # export into current shell
#   cache-env                        # print paths
#   cache-env --ensure               # mkdir -p cache subdirs (needs write access)
#   cache-env --write-yarnrc         # classic Yarn 1 .yarnrc in cwd
#   cache-env --write-yarnrc-yml     # modern Yarn (Berry) .yarnrc.yml in cwd
#   cache-env --write-npmrc          # write .npmrc cache= in cwd
#   cache-env --write-pip-conf       # write pip.conf (cache-dir) in cwd or --user
#   cache-env --link-bundler         # symlink shared bundler-flags.yml → .bundle/config

set -euo pipefail

_CACHE_SUBDIRS=(mise mise-cache bundle rubygems yarn yarn-cache yarn-global npm pip uv poetry)

_cache_env_detect_share() {
  local d
  for d in \
    /usr/local/share/ubuntu-mise \
    /usr/local/share/alpine-mise \
    /usr/local/share/arch-mise; do
    if [[ -d "${d}" ]]; then
      printf '%s\n' "${d}"
      return 0
    fi
  done
  return 1
}

_cache_env_main() {
  CACHE_ROOT="${CACHE_ROOT:-/cache}"
  export CACHE_ROOT
  export MISE_DATA_DIR="${MISE_DATA_DIR:-${CACHE_ROOT}/mise}"
  export MISE_CACHE_DIR="${MISE_CACHE_DIR:-${CACHE_ROOT}/mise-cache}"
  export BUNDLE_PATH="${BUNDLE_PATH:-${CACHE_ROOT}/bundle}"
  export BUNDLE_CACHE_PATH="${BUNDLE_CACHE_PATH:-${CACHE_ROOT}/rubygems}"
  # Shared BUNDLE_PATH: never prune gems not listed in the current Gemfile.
  export BUNDLE_CLEAN="${BUNDLE_CLEAN:-false}"
  # Classic Yarn 1 cache-folder + Berry cacheFolder (env name is shared).
  export YARN_CACHE_FOLDER="${YARN_CACHE_FOLDER:-${CACHE_ROOT}/yarn-cache}"
  # Classic offline mirror only (not used by Berry).
  export YARN_OFFLINE_MIRROR="${YARN_OFFLINE_MIRROR:-${CACHE_ROOT}/yarn}"
  # Berry globalFolder + enableGlobalCache (YARN_* → .yarnrc.yml settings).
  export YARN_GLOBAL_FOLDER="${YARN_GLOBAL_FOLDER:-${CACHE_ROOT}/yarn-global}"
  export YARN_ENABLE_GLOBAL_CACHE="${YARN_ENABLE_GLOBAL_CACHE:-true}"
  export NPM_CONFIG_CACHE="${NPM_CONFIG_CACHE:-${CACHE_ROOT}/npm}"
  export npm_config_cache="${npm_config_cache:-${NPM_CONFIG_CACHE}}"
  # Python (pip / uv / poetry caches are separate on disk).
  export PIP_CACHE_DIR="${PIP_CACHE_DIR:-${CACHE_ROOT}/pip}"
  export UV_CACHE_DIR="${UV_CACHE_DIR:-${CACHE_ROOT}/uv}"
  export POETRY_CACHE_DIR="${POETRY_CACHE_DIR:-${CACHE_ROOT}/poetry}"
  export POETRY_VIRTUALENVS_IN_PROJECT="${POETRY_VIRTUALENVS_IN_PROJECT:-true}"
}

_cache_env_ensure() {
  local d
  mkdir -p "${CACHE_ROOT}"
  for d in "${_CACHE_SUBDIRS[@]}"; do
    mkdir -p "${CACHE_ROOT}/${d}"
  done
  echo "ensured dirs under ${CACHE_ROOT}"
}

_cache_env_write_yarnrc() {
  # Classic Yarn 1.x — do not use in Berry projects (use --write-yarnrc-yml).
  local mirror="${YARN_OFFLINE_MIRROR}"
  if [[ -f .yarnrc.yml ]] || [[ -f .yarnrc.yaml ]]; then
    echo "warning: .yarnrc.yml present — this project looks like Yarn Berry;" >&2
    echo "         classic .yarnrc is ignored by modern Yarn. Prefer:" >&2
    echo "           cache-env --write-yarnrc-yml" >&2
  fi
  cat >.yarnrc <<EOF
# Classic Yarn 1.x — generated by cache-env --write-yarnrc
# Offline mirror: ${mirror}
# YARN_CACHE_FOLDER is set via environment (not this file).
# For Yarn Berry (2+), use: cache-env --write-yarnrc-yml

yarn-offline-mirror "${mirror}"
# Keep tarballs for other projects sharing /cache/yarn (do not prune).
yarn-offline-mirror-pruning false

--install.ignore-engines true
EOF
  echo "Wrote $(pwd)/.yarnrc (classic offline-mirror → ${mirror})"
}

_cache_env_write_yarnrc_yml() {
  # Modern Yarn (Berry 2+) — YAML config; classic .yarnrc is a different file.
  local global_folder="${YARN_GLOBAL_FOLDER}"
  local cache_folder="${YARN_CACHE_FOLDER}"
  if [[ -f .yarnrc ]] && ! [[ -f .yarnrc.yml ]]; then
    echo "warning: classic .yarnrc present — Yarn 1 projects should keep using it;" >&2
    echo "         Berry reads .yarnrc.yml. Both can coexist but only one Yarn major applies." >&2
  fi
  cat >.yarnrc.yml <<EOF
# Modern Yarn (Berry 2+) — generated by cache-env --write-yarnrc-yml
# Global + package cache under ${CACHE_ROOT} for multi-container reuse.
# Classic Yarn 1 ignores this file; use: cache-env --write-yarnrc
#
# Equivalent env (already set in the image):
#   YARN_ENABLE_GLOBAL_CACHE=true
#   YARN_GLOBAL_FOLDER=${global_folder}
#   YARN_CACHE_FOLDER=${cache_folder}

enableGlobalCache: true

globalFolder: "${global_folder}"

cacheFolder: "${cache_folder}"
EOF
  echo "Wrote $(pwd)/.yarnrc.yml (Berry globalFolder → ${global_folder}, cacheFolder → ${cache_folder})"
}

_cache_env_write_npmrc() {
  cat >.npmrc <<EOF
# Generated by cache-env --write-npmrc
cache=${NPM_CONFIG_CACHE}
prefer-offline=true
EOF
  echo "Wrote $(pwd)/.npmrc (cache → ${NPM_CONFIG_CACHE})"
}

_cache_env_write_pip_conf() {
  # Optional file config; PIP_CACHE_DIR env is already set in the image.
  # Writes project-local pip.conf (PIP_CONFIG_FILE) or user config with --user.
  local dest mode="${1:-}"
  if [[ "${mode}" == "--user" ]]; then
    dest="${HOME}/.config/pip/pip.conf"
    mkdir -p "$(dirname "${dest}")"
  else
    dest="$(pwd)/pip.conf"
  fi
  cat >"${dest}" <<EOF
# Generated by cache-env --write-pip-conf
# Prefer env PIP_CACHE_DIR=${PIP_CACHE_DIR} (already set in the image).
[global]
cache-dir = ${PIP_CACHE_DIR}
EOF
  if [[ "${mode}" != "--user" ]]; then
    echo "Wrote ${dest} (use: export PIP_CONFIG_FILE=${dest})"
  else
    echo "Wrote ${dest}"
  fi
}

_cache_env_link_bundler() {
  local share flags
  share="$(_cache_env_detect_share)" || {
    echo "error: shared bundler-flags.yml not found under /usr/local/share/*-mise" >&2
    return 1
  }
  flags="${share}/bundler-flags.yml"
  mkdir -p .bundle
  ln -sfn "${flags}" .bundle/config
  echo "Linked .bundle/config → ${flags}"
}

_cache_env_print() {
  printf 'CACHE_ROOT=%s\n' "${CACHE_ROOT}"
  printf 'MISE_DATA_DIR=%s\n' "${MISE_DATA_DIR}"
  printf 'MISE_CACHE_DIR=%s\n' "${MISE_CACHE_DIR}"
  printf 'BUNDLE_PATH=%s\n' "${BUNDLE_PATH}"
  printf 'BUNDLE_CACHE_PATH=%s\n' "${BUNDLE_CACHE_PATH}"
  printf 'YARN_CACHE_FOLDER=%s\n' "${YARN_CACHE_FOLDER}"
  printf 'YARN_OFFLINE_MIRROR=%s\n' "${YARN_OFFLINE_MIRROR}"
  printf 'YARN_GLOBAL_FOLDER=%s\n' "${YARN_GLOBAL_FOLDER}"
  printf 'YARN_ENABLE_GLOBAL_CACHE=%s\n' "${YARN_ENABLE_GLOBAL_CACHE}"
  printf 'NPM_CONFIG_CACHE=%s\n' "${NPM_CONFIG_CACHE}"
  printf 'PIP_CACHE_DIR=%s\n' "${PIP_CACHE_DIR}"
  printf 'UV_CACHE_DIR=%s\n' "${UV_CACHE_DIR}"
  printf 'POETRY_CACHE_DIR=%s\n' "${POETRY_CACHE_DIR}"
  printf 'POETRY_VIRTUALENVS_IN_PROJECT=%s\n' "${POETRY_VIRTUALENVS_IN_PROJECT}"
}

_cache_env_main

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  case "${1:-}" in
    "" )
      _cache_env_print
      ;;
    --ensure)
      _cache_env_ensure
      ;;
    --write-yarnrc)
      _cache_env_write_yarnrc
      ;;
    --write-yarnrc-yml|--write-yarnrc.yml)
      _cache_env_write_yarnrc_yml
      ;;
    --write-npmrc)
      _cache_env_write_npmrc
      ;;
    --write-pip-conf)
      _cache_env_write_pip_conf "${2:-}"
      ;;
    --link-bundler)
      _cache_env_link_bundler
      ;;
    -h|--help)
      cat <<'EOF'
Usage:
  source cache-env              # export cache paths
  cache-env                     # print paths
  cache-env --ensure            # mkdir -p under CACHE_ROOT
  cache-env --write-yarnrc      # classic Yarn 1 .yarnrc (offline mirror)
  cache-env --write-yarnrc-yml  # modern Yarn Berry .yarnrc.yml (global cache)
  cache-env --write-npmrc       # .npmrc cache= in cwd
  cache-env --write-pip-conf    # pip.conf cache-dir in cwd
  cache-env --write-pip-conf --user  # ~/.config/pip/pip.conf
  cache-env --link-bundler      # .bundle/config → shared bundler-flags.yml

Yarn classic vs Berry (do not mix package caches):
  Yarn 1:   YARN_CACHE_FOLDER + YARN_OFFLINE_MIRROR + --write-yarnrc
  Yarn 2+:  YARN_CACHE_FOLDER + YARN_GLOBAL_FOLDER + YARN_ENABLE_GLOBAL_CACHE
            + --write-yarnrc-yml (optional; env alone often enough)

Python (env alone is enough; caches are separate on disk):
  pip:     PIP_CACHE_DIR=/cache/pip
  uv:      UV_CACHE_DIR=/cache/uv
  poetry:  POETRY_CACHE_DIR=/cache/poetry + POETRY_VIRTUALENVS_IN_PROJECT=true
           (venvs stay in-project .venv; only package cache is shared)
EOF
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
fi
