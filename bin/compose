#!/usr/bin/env bash
# docker compose wrapper: writes .env (UID/GID, absolute PROJECT_MOUNT) then runs compose.
#
# Usage:
#   bin/compose build
#   bin/compose run --rm dev bash -l
#   bin/compose run --rm dev mise --version
#   bin/compose up
#   bin/compose down
#   PROJECT=/path/to/app bin/compose run --rm dev bash -l
#
# Parallel to bin/shell / bin/run (plain docker run). Prefer this when you want
# Compose features (overrides, multi-service later, `compose config`).
set -euo pipefail
# shellcheck source=lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"

COMPOSE_FILE="${COMPOSE_FILE:-${ROOT}/compose.yml}"
ENV_FILE="${COMPOSE_ENV_FILE:-${ROOT}/.env}"
COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-${FLAVOR}}"

require_docker
command -v docker >/dev/null 2>&1 || die "docker not found"
docker compose version >/dev/null 2>&1 || die "docker compose plugin not available"

if [[ ! -f "${COMPOSE_FILE}" ]]; then
  die "missing ${COMPOSE_FILE}"
fi

# Absolute path for bind mount (compose resolves relative paths vs compose file dir).
if [[ ! -d "${PROJECT}" ]]; then
  die "PROJECT is not a directory: ${PROJECT}"
fi
PROJECT_MOUNT="$(cd "${PROJECT}" && pwd)"

write_compose_env() {
  cat >"${ENV_FILE}" <<EOF
# Generated by bin/compose — do not commit (see .gitignore / compose.env.example)
IMAGE=${IMAGE}
IMAGE_USER=${IMAGE_USER}
DEV_UID=${DEV_UID}
DEV_GID=${DEV_GID}
CACHE_VOLUME=${CACHE_VOLUME}
CACHE_ROOT=${CACHE_ROOT}
PROJECT_MOUNT=${PROJECT_MOUNT}
COMPOSE_PROJECT_NAME=${COMPOSE_PROJECT_NAME}
EOF
  log "wrote ${ENV_FILE} (PROJECT_MOUNT=${PROJECT_MOUNT})"
}

write_compose_env
# Same named volume as bin/shell (compose.yml marks cache external).
ensure_cache_volume

# shellcheck disable=SC2086
exec docker compose \
  --project-directory "${ROOT}" \
  --env-file "${ENV_FILE}" \
  -f "${COMPOSE_FILE}" \
  ${COMPOSE_OPTS:-} \
  "$@"
