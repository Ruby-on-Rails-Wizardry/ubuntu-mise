#!/usr/bin/env bash
# Best-effort warm of mise tools + project package managers inside the image.
# Detects lockfiles/markers under PROJECT (/work). No-ops when nothing matches.
set -euo pipefail
# shellcheck source=lib.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib.sh"

ensure_image
ensure_cache_volume

log "warming with PROJECT=${PROJECT}"

# Run warm logic inside the container so host needs no Ruby/Node/Python.
run_in_image bash -lc '
set -euo pipefail
cd /work
echo "== warm: pwd=$(pwd) =="

if command -v cache-env >/dev/null 2>&1; then
  cache-env --ensure || true
  cache-env || true
fi

if [[ -f mise.toml ]] || [[ -f .tool-versions ]]; then
  echo "== warm: mise install =="
  if command -v mise >/dev/null 2>&1; then
    mise trust . 2>/dev/null || true
    mise install || echo "warning: mise install failed (continuing)"
  else
    echo "warning: mise not on PATH"
  fi
else
  echo "== warm: no mise.toml / .tool-versions — skip mise =="
fi

# Re-activate so newly installed shims are visible in this shell.
eval "$(mise activate bash)" 2>/dev/null || true

if [[ -f Gemfile ]]; then
  echo "== warm: bundle install =="
  if command -v bundle >/dev/null 2>&1; then
    bundle install || echo "warning: bundle install failed"
  else
    echo "warning: bundle not available (install ruby via mise first)"
  fi
fi

if [[ -f package.json ]]; then
  if [[ -f yarn.lock ]]; then
    if [[ -f .yarnrc.yml ]] || [[ -f .yarnrc.yaml ]]; then
      echo "== warm: yarn (Berry) =="
      command -v yarn >/dev/null 2>&1 && yarn install || echo "warning: yarn install failed"
    else
      echo "== warm: yarn classic =="
      if command -v yarn >/dev/null 2>&1; then
        command -v cache-env >/dev/null 2>&1 && cache-env --write-yarnrc 2>/dev/null || true
        yarn install || echo "warning: yarn install failed"
      else
        echo "warning: yarn not available"
      fi
    fi
  elif [[ -f pnpm-lock.yaml ]]; then
    echo "== warm: pnpm =="
    command -v pnpm >/dev/null 2>&1 && pnpm install || echo "warning: pnpm install failed"
  elif [[ -f package-lock.json ]]; then
    echo "== warm: npm =="
    command -v npm >/dev/null 2>&1 && npm ci 2>/dev/null || npm install || echo "warning: npm install failed"
  else
    echo "== warm: package.json without lockfile — skip js =="
  fi
fi

if [[ -f uv.lock ]] || [[ -f pyproject.toml ]]; then
  if command -v uv >/dev/null 2>&1; then
    echo "== warm: uv =="
    if [[ -f uv.lock ]]; then
      uv sync || echo "warning: uv sync failed"
    else
      echo "pyproject.toml present; run uv sync manually if desired"
    fi
  elif [[ -f requirements.txt ]] && command -v pip >/dev/null 2>&1; then
    echo "== warm: pip (requirements.txt) =="
    pip install -r requirements.txt || echo "warning: pip install failed"
  else
    echo "warning: python project markers found but uv/pip not available"
  fi
elif [[ -f requirements.txt ]]; then
  echo "== warm: pip =="
  if command -v pip >/dev/null 2>&1; then
    pip install -r requirements.txt || echo "warning: pip install failed"
  else
    echo "warning: pip not available (install python via mise first)"
  fi
fi

if [[ -f poetry.lock ]] || { [[ -f pyproject.toml ]] && grep -q "\[tool.poetry\]" pyproject.toml 2>/dev/null; }; then
  if command -v poetry >/dev/null 2>&1; then
    echo "== warm: poetry install =="
    poetry install || echo "warning: poetry install failed"
  fi
fi

echo "== warm: done =="
'
